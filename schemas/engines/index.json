      "title": "Participant Treaty Impact Simulator",
      "engine_category": "treaty"
    },
    {
      "id": "cross_treaty_optimization_engine",
      "file": "treaty/cross-treaty-optimization-engine.json",
      "title": "Cross-Treaty Optimization Engine",
      "engine_category": "treaty"
    },
    {
      "id": "participant_law_impact_simulator",
      "file": "law/participant-law-impact-simulator.json",
      "title": "Participant Law Impact Simulator",
      "engine_category": "law"
    },
    {
      "id": "cross_law_optimization_engine",
      "file": "law/cross-law-optimization-engine.json",
      "title": "Cross-Law Optimization Engine",
      "engine_category": "law"
    },
    {
      "id": "law_harmonization_engine",
      "file": "law/law-harmonization-engine.json",
      "title": "Law Harmonization Engine",
      "engine_category": "law"
    },
    {
      "id": "policy_impact_engine",
      "file": "policy/policy-impact-engine.json",
      "title": "Policy Impact Engine",
      "engine_category": "policy"
    },
    {
      "id": "law_treaty_interaction_engine",
      "file": "cross-layer/law-treaty-interaction-engine.json",
      "title": "Law–Treaty Interaction Engine",
      "engine_category": "cross_layer"
