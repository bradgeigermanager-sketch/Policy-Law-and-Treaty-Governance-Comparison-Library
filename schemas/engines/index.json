{
  "$id": "engines/index.json",
  "title": "Engine Schema Index",
  "type": "object",

  "description": "Index of all engine schemas in the Governance OS.",

  "properties": {
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "file": { "type": "string" },
          "title": { "type": "string" },
          "engine_category": {
            "type": "string",
            "enum": [
              "treaty",
              "law",
              "policy",
              "cross_layer",
              "simulation",
              "dag"
            ]
          }
        },
        "required": ["id", "file", "title", "engine_category"]
      }
    }
  },

  "required": ["schemas"],

  "schemas": [
    {
      "id": "participant_treaty_impact_simulator",
