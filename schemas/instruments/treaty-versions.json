{
  "$id": "instruments/treaty-versions.json",
  "type": "object",
  "title": "TreatyVersion",
  "properties": {
    "id": { "type": "string", "pattern": "^treaty_version\\." },
    "treaty_id": { "type": "string", "pattern": "^treaty\\." },
    "version": { "type": "string" },
    "effective_from": { "type": "string", "format": "date-time" },
    "effective_to": { "type": ["string", "null"], "format": "date-time" },
    "parties": {
      "type": "array",
      "items": { "type": "string", "pattern": "^party\\." }
    }
  },
  "required": ["id", "treaty_id", "version", "effective_from"]
}
